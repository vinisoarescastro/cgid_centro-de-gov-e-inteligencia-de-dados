# ============================================================
# CGID Backend — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================================

# --- Banco de dados ---
# Autenticação Windows (sem usuário/senha) — recomendado para dev local
DATABASE_URL=mssql+pyodbc://@localhost\SQLEXPRESS/btportal?driver=ODBC+Driver+17+for+SQL+Server&TrustServerCertificate=yes&trusted_connection=yes

# Autenticação SQL (usuário/senha)
# DATABASE_URL=mssql+pyodbc://sa:SuaSenha@localhost\SQLEXPRESS/btportal?driver=ODBC+Driver+17+for+SQL+Server&TrustServerCertificate=yes

# Servidor on-premise da empresa
# DATABASE_URL=mssql+pyodbc://USUARIO:SENHA@SERVIDOR\INSTANCIA/btportal?driver=ODBC+Driver+17+for+SQL+Server

# --- JWT ---
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=troque-por-uma-chave-longa-e-aleatoria-gerada-com-secrets

JWT_ALGORITMO=HS256

# Tempo de vida do access token (minutos)
JWT_EXPIRA_MINUTOS=60

# Tempo de vida do refresh token (dias)
JWT_REFRESH_EXPIRA_DIAS=30

# --- Servidor ---
PORTA=3001
AMBIENTE=development

# --- CORS ---
URL_FRONTEND=http://localhost:5173
